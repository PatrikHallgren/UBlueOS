# Ghostty terminal default config
# https://ghostty.org/docs/configuration

font-family = "Cascadia Code"
font-size = 12
theme = "gruvbox-dark"

background-opacity = 0.92
window-padding-x = 4
window-padding-y = 4

shell-integration = "zsh"
copy-on-select = "clipboard"

cursor-style = "block"
cursor-style-blink = false
